generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Texte {
  id          String       @id @default(cuid())
  ownerId     String       @map("owner_id")
  reference   String
  content     String       @default("")
  source      String?
  scanKey     String?      @map("scan_key")
  createdAt   DateTime     @default(now()) @map("created_at")
  annotations Annotation[]

  @@index([ownerId])
  @@map("texte")
}

model Tag {
  id          String       @id @default(cuid())
  ownerId     String       @map("owner_id")
  layer       String
  code        String
  label       String?
  annotations Annotation[]

  @@unique([ownerId, layer, code])
  @@index([ownerId])
  @@index([layer])
  @@map("tag")
}

model Annotation {
  id        String   @id @default(cuid())
  ownerId   String   @map("owner_id")
  texteId   String   @map("texte_id")
  start     Int
  end       Int
  tagId     String   @map("tag_id")
  note      String?
  createdAt DateTime @default(now()) @map("created_at")
  texte     Texte    @relation(fields: [texteId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id])

  @@index([ownerId])
  @@index([texteId])
  @@index([tagId])
  @@index([texteId, start, end])
  @@map("annotation")
}
